		Configs: {
			ConfigClient: {
				DisplayName: 用户设置

				xenoHaloShields: {
					Label: "[i:ArtificerMod/XenoSuit]外星盔甲护盾音效调整"
					Tooltip:
						'''
						切换外星盔甲护盾的音效，使用模组音效或原版音效
						音效在护盾充能,受伤/损坏时出现
						关闭后，不会产生充能音效，受伤/损坏时使用原版音效
						声明: 模组使用的音效源自《光环》，所有权归音效制作者享有
						'''
				}

				cooldownAwareness: {
					Label: "[i:ArtificerMod/ClockworkStopwatch]增加能力冷却提示"
					Tooltip:
						'''
						开关饰品技能冷却结束时，出现的额外视觉效果
						开启后，为技能冷却添加额外的粒子效果和文字提示提醒玩家
						如果外星盔甲护盾音效调整(见上)开启，刷新音效也会被替换
						默认关闭
						'''
				}

				ultrasightZoom: {
					Label: "[i:ArtificerMod/UltrasightHelmet] 超视距头盔可拉远视野"
					Tooltip:
						'''
						开关超视距头盔和全能头盔拉远视野的能力(类似狙击镜效果)
						如果你觉得戴着头盔执行某些任务时缩放很烦人，这可能会很有用
						注意，这个选项不影响凝视者护目镜，即使它具有相同的能力
						'''
				}
			}

			ConfigServer: {
				DisplayName: 服务器设置

				CultistExpertDrop: {
					Label: "[i:ArtificerMod/DarkmoonPact]拜月教邪教徒专家掉落"
					Tooltip:
						'''
						让你决定在专家模式下，拜月教邪教徒如何掉落他的战利品
						本模组为邪教徒额外添加了专家模式战利品，会从宝藏袋中开出，但原版无法掉落邪教徒宝藏袋
						选择'Drop Bag'时邪教徒掉落宝藏袋，可从宝藏袋开出模组饰品
						选择'No Drops'时邪教徒不掉落宝藏袋，也无法获得战利品
						选择'No Bag'时邪教徒不掉落宝藏袋，邪教徒直接掉落战利品
						如果你添加的其他模组也让邪教者掉落宝藏袋，这个选项可以避免多个宝藏袋同时掉落引发的问题
						'''
				}

				GodmodeCooldown: {
					Label: "[i:ArtificerMod/NovaEmblem]旅途无敌模式能力冷却变短"
					Tooltip:
						'''
						开启后，旅途模式的无敌模式下，饰品技能冷却时间减少75%
						同时取消未穿戴整套盔甲和佩戴技能饰品时的冷却时间惩罚
						使旅程模式更容易测试各种能力效果
						默认关闭
						'''
				}

				PresentDeathText: {
					Label: "[i:ArtificerMod/LuckyPresent]幸运礼盒特殊死亡讯息"
					Tooltip:
						'''
						开启后，如果玩家被幸运礼盒的随机效果击杀，会出现特殊的死亡信息提示
						请注意，正常情况下玩家不会被这样击杀，因为幸运礼物只会把玩家生命值削减为1
						默认开启
						'''
				}

				BonusArtificerSlot: {
					Label: "[i:ArtificerMod/AstralCuirass]巧匠盔甲额外+1饰品栏"
					Tooltip:
						'''
						开启后，巧匠盔甲套装奖励将额外多提供1个巧匠饰品栏
						例：冠军套装正常提供2个饰品栏，开启后则提供3个
						为了保持游戏平衡性，只建议在你有大量其它模组的饰品要装备时，再开启本选项
						默认关闭
						'''
				}

				CrossmodStats: {
					Label: "[i:ArtificerMod/AstralCuirassG]巧匠盔甲增强模组职业属性"
					Tooltip:
						'''
						开启后,巧匠盔甲的很多部件和套装奖励将会强化一些模组职业的属性
						以下是支持的模组职业;
						-捕猎者(捕猎碟职业模组)
						-吟游诗人,牧师(瑟银模组)
						-点击者(点击者职业模组)
						-盗贼(灾厄模组)
						注意,不论是否开启设置，一些部件都会加强投掷属性
						这些部件应该会加强大多数模组的投手，只要它使用tML内置的投手职业
						'''
				}
			}
		}
	}
}
