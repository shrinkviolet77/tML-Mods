					生命值低于50%时，产生一颗围着玩家旋转的尖刺冰龟壳，伤害敌人并减少25%受到的伤害
					受到伤害时，冰龟壳会撞向敌人并爆炸
					冰龟壳爆炸后迅速产生一个新的冰龟壳
					免疫冷冻、冰冻和霜火
					'蓝龟壳?!'
					'''
			}

			ClockworkStopwatch: {
				DisplayName: 发条秒表
				Tooltip:
					'''
					{$CommonItemtooltip.ForItems.ReducedAbilityCooldown}
					战斗中自动使用饰品技能
					'一秒不差'
					'''
			}

			ArtificerArm: {
				DisplayName: 巧匠机械臂
				Tooltip:
					'''
					你的攻击将会充电，攻击时有几率电击敌人
					增加15%近战和鞭子速度
					为近战武器和鞭子启用自动挥舞
					'我渴望钢铁般的力量和坚定...'
					'''
			}

			TerraShield: {
				DisplayName: 泰拉之盾
				Tooltip:
					'''
					{$CommonItemtooltip.ForItems.NoKnockback}
					免疫大部分减益
					生命值高于25%时，附近的盟友受到免死保护；生命值低于25%时，只有你受到保护
					受保护玩家受到致命伤害时会保留1点生命值
					效果触发后，该玩家暂时免疫伤害并加强下一次近战攻击
					此效果有60秒冷却,装备此盾可以降低25%冷却时间
					'''
			}

			TwinShield: {
				DisplayName: 双子护盾
				Tooltip:
					'''
					{$CommonItemtooltip.ForItems.NoKnockback}
					有几率向前方的敌人发射激光
					获得向敌人冲刺的能力
					双击方向键
					'''
			}

			DestroyerScarf: {
				DisplayName: 毁灭者围巾
				Tooltip:
					'''
					减少18%受到的伤害
					增加8点护甲穿透
					'''
			}

			MotherboardOfIllusion: {
				DisplayName: 幻象主板
				Tooltip:
					'''
					{$CommonItemtooltip.ForItems.LessTarget}
					有几率制造幻象并闪避攻击
					闪避后暂时增加伤害，且敌人不容易以你为目标
					被击中后可能使附近敌人陷入困惑
					'''
			}

			LifeWell: {
				DisplayName: 生命之井
				Tooltip:
					'''
					治疗药水冷却时间降低25%
					需要时自动使用治疗药水
					'''
			}

			EtherealCharm: {
				DisplayName: 空灵护身符
				Tooltip:
					'''
					{$CommonItemTooltip.PercentReducedManaCost}
					需要时自动使用魔力药水
					{$CommonItemTooltip.IncreasesMaxManaBy@1}
					当外观可见时，使大多数魔法武器隐形
					'''
			}

			AncientChampionsHeadpiece: {
				DisplayName: 远古冠军头饰
				Tooltip:
					'''
					{$CommonItemTooltip.PercentIncreasedDamage}
					{$CommonItemTooltip.PercentIncreasedCritChance@1}
					{$CommonItemTooltip.PercentChanceToSaveAmmo@2}
					'虽然已经陈旧不堪，但被守护魔法强化了防御能力'
					'''
			}

			NovaHologliderG: {
				DisplayName: 远古新星滑翔机
				Tooltip:
					'''
					可飞行与缓慢降落
					'绿的'
					'''
			}

			AstralCuirassG: {
				DisplayName: 远古新星护胸
				Tooltip:
					'''
					{$CommonItemTooltip.PercentIncreasedDamage}
					{$CommonItemTooltip.PercentIncreasedCritChance@1}
					{$CommonItemTooltip.IncreasesMaxMinionsBy@2}
					稍微增加生命再生速度
					'''
			}

			AstralGreavesG: {
				DisplayName: 远古新星护胫
				Tooltip:
					'''
					{$CommonItemTooltip.IncreasesMaxManaBy}
					{$CommonItemTooltip.PercentIncreasedDamageCritChance@1}
					增加10%投掷物飞行速度
					{$CommonItemTooltip.PercentIncreasedMovementSpeed@2}
					'''
			}

			AstralHeadgearG: {
				DisplayName: 远古新星头饰
				Tooltip:
					'''
					{$CommonItemTooltip.PercentIncreasedDamage}
					{$CommonItemTooltip.PercentIncreasedCritChance@1}
					{$CommonItemTooltip.PercentReducedManaCost@2}
					{$CommonItemTooltip.PercentChanceToSaveAmmo@3}
					{$CommonItemTooltip.IncreasesMaxMinionsBy@4}
					'''
			}

			WeatherBottle: {
				DisplayName: 天气瓶
				Tooltip: 持有者可以四段跳
			}

			AquaticBoots: {
				DisplayName: 水栖靴
				Tooltip: 给予在水和蜂蜜上行走和游泳的能力
			}

			MerfolkBoots: {
				DisplayName: 人鱼之靴
				Tooltip:
					'''
					穿戴者可飞速奔跑
					增加跳跃速度并启用自动跳跃
					增加摔落抗性
					给予在水和蜂蜜上行走和游泳的能力
					'''
			}

			WingRing: {
				DisplayName: 飞翼戒指
				Tooltip: 增加翅膀的飞行时间
			}

			SkywardShoes: {
				DisplayName: 天行鞋
				Tooltip:
					'''
					小幅增加翅膀的飞行时间
					增加摔落抗性
					获得垂直冲刺能力
                    双击向上或向下冲刺
					垂直冲刺消耗飞行时间，没有翅膀时只能从地面冲刺
					'''
			}

			CrashBoots: {
				DisplayName: 冲击靴
				Tooltip:
					'''
					获得冲刺能力
					双击方向键冲刺
					空中按住下键快速下落
					对击退和火块免疫
					抵抗太空的重力降低效果，增加摔落抗性
					'''
			}

			SinisterEffigy: {
				DisplayName: 不祥雕像
				Tooltip:
					'''
					{$CommonItemtooltip.ForItems.ActivatedAbility}在你周围散发持续10秒的黑暗光环
					进入光环的敌人的伤害暂时降低10%
					削弱敌人能使你的伤害暂时提高10%
					[placeholder]
					'''
			}

			PrimevalRelic: {
				DisplayName: 原始圣物
				Tooltip:
					'''
					{$CommonItemtooltip.ForItems.ActivatedAbility}在你周围散发持续10秒的大型光环
					进入光环的敌人暂时移速降低并降低30防御力
					削弱敌人能强化你的生命再生
					敌人被削弱的时间越长，再生的效果越强
					'看着更像是个奖杯'
					'''
			}

			GamblerFallacy: {
				DisplayName: 赌徒悖论
				Tooltip:
					'''
					{$CommonItemtooltip.ForItems.ActivatedAbility}掷出硬币骰子
					骰子会爆裂成伤害敌人并可拾取的钱币
					越值钱的硬币越稀有，伤害也更高
					'去赌一把!'
					'''
			}

			WrithingFlesh: {
				DisplayName: 扭动血肉
				Tooltip:
					'''
					{$CommonItemtooltip.ForItems.ActivatedAbility}召唤3个连接在你身上的饿鬼
					饿鬼会攻击附近的敌人并吸取生命值
					然而使用技能需要消耗50生命值!
					[placeholder]
					'''
			}
		}

