					'虽然看起来不祥，但据说它能给持有者带来出奇的好运气'
					'''
			}

			LuckyPresent: {
				DisplayName: 幸运礼盒
				Tooltip:
					'''
					{$CommonItemtooltip.ForItems.ActivatedAbility}对你施加随机的效果，可能有益也可能有害...
					'我能得到什么？我想知道我将得到什么?'
					'''
			}

			StellarResonator: {
				DisplayName: 恒星谐振器
				Tooltip:
					'''
					技能冷却时增加4%伤害和暴击率
					{$CommonItemtooltip.ForItems.ActivatedAbility}花费10秒为极其强大的星光束充能
					充能时，减少20%受到的伤害
					充能完成后，星光束将寻找最强的敌人，引发毁灭性的小范围超新星爆炸
					'向星星许愿，它们会回应'
					'''
			}

			MoonbiteMark: {
				DisplayName: 月噬标记
				Tooltip:
					'''
					{$CommonItemtooltip.ForItems.ActivatedAbility}释放大量飞升吸血鬼刀，吸收击中的敌人的生命值
					当你被吸血治疗时，附近的队友也有可能得到少量的治疗
					略微提高你的吸血能力
					'献给Jason 'Lienfors' Parker'
					'死亡是短暂的；贡献是永恒的'
					'''
			}

			StarlightArmillary: {
				DisplayName: 星光浑仪
				Tooltip:
					'''
					{$CommonItemtooltip.ForItems.ActivatedAbility}召唤北极光，暂时保护你免受所有攻击
					极光附近的玩家(包括使用者)将暂时提高生存能力
					极光附近的敌人陷入困惑，并在短时间内受到额外伤害
					'它洋溢的天界力量似乎是反转秘术的残余...'
					'''
			}

			Moonfall: {
				DisplayName: 月落
				Tooltip:
					'''
					{$CommonItemtooltip.ForItems.ActivatedAbility}召唤轨道打击，从上方发射巨大光束
					光束持续20秒，缓慢跟随光标
					'月亮来了，嘟嘟嘟...'
