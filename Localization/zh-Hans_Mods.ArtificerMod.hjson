Mods: {
	ArtificerMod: {
		CommonItemtooltip: {
			HotkeySet: 警告: 请在设置菜单中<控件>选项为本模组的“饰品技能”绑定快捷键
			BonusAccessory: 额外巧匠饰品栏
			GemsforRecipe: 宝石
			AbilitiesRefreshed: 饰品技能已刷新！
			RecipeBrowserFilter: 技能饰品

			Cooldown: {
				CooldowntimeNegative: 当前冷却:[c/78be78:{1}秒](基础冷却:{0}秒)
				CooldowntimePositive: 当前冷却:[c/be7878:{1}秒](基础冷却:{0}秒)
				Cooldowntime: 当前冷却:{1}秒(基础冷却:{0}秒)
				SlightlyExtended: 未穿戴整套巧匠盔甲时，冷却时间小幅增加
				GreatlyExtended: 未佩戴技能饰品时，冷却时间大幅增加
				DrasticallyExtended: 未穿戴整套巧匠盔甲或未佩戴技能饰品时，冷却时间巨幅增加
			}

			ForBuffs: {
				RegeneratingHealth: 正在快速恢复生命
				RegeneratingMana: 正在快速恢复魔力
				Lucky: 幸运!
				Unlucky: 霉运...
				IncreasedCriticalChance: 增加暴击率
				DecreasedCriticalChance: 降低暴击率
				IncreasedDefense: 增加防御
				DecreasedDefense: 降低防御
				IncreasedDamage: 增加伤害
				DecreasedDamage: 降低伤害
				DecreasedDamageTaken: 降低受到的伤害
				IncreasedDamageTaken: 增加受到的伤害
			}

			ForItems: {
				ActivatedAbility: "主动技能: "
				BrieflyLifeRegen: 治愈减益时大幅增加生命再生速度
				ManaSicknessInflicted: 回复期间获得魔力病减益
				PotionSicknessInflicted: 回复期间获得抗药性减益
				SlowlyRegeneratesLife: 缓慢回复生命
				NoKnockback: 免疫击退
				ArcanaStimulator: 10秒内回复{0}魔力值
				VitalStimulator: 5秒内回复{0}生命值
				LeechedLifeHeal:
					'''
					发射扎在敌人身上吸取生命的刺钩，持续5秒
					吸取的生命将用于治疗生命值最低的玩家
					被吸取的敌人在之后还会继续损失生命值一段时间
					'''
				ReducedAbilityCooldown: "降低{0}%饰品技能冷却时间"
				PercentIncreasedWhipSpeed: "增加{0}%鞭子攻击速度"
				PercentIncreasedWhipRange: "增加{0}%鞭子攻击范围"
				MoreTarget: 敌人倾向于将你视作攻击目标
				LessTarget: 敌人不容易将你视作攻击目标
				AccessorySlot: 巧匠饰品栏
			}

			CaptureClass: {
				IncTrailLength: "增加{0}%捕猎碟轨迹长度"
				IncCaptureSpd: "增加{0}%捕获速度"
			}

			Thorium: {
				BardBuffRange: 咒音增幅效果半径增加{0}格
				BardBuffTime: 咒音增幅效果延长{0} {^0:秒;秒}
				BardInspiration: 最大灵感值增加{0}
				HealerBonusHeal: 增加{0}点额外治疗量
			}

			Clicker: {
				IncClickRadius: 直接{0}基础点击半径
				CheaperEffect: 点击特效所需点击数减少{0}
			}

			Rogue.IncStealth: +{0}最大潜伏值

			Armorset: {
				AstralNova:
					'''
					+3{$CommonItemtooltip.ForItems.AccessorySlot}
					减少25%饰品技能冷却时间
					使用饰品技能会释放大量能量，在冷却期间提高你的进攻和防御能力
					'''
				Champions:
					'''
					+2{$CommonItemtooltip.ForItems.AccessorySlot}
					泰拉之力会根据你的生命值提高伤害或生存能力
					'''
				Lihzahrd:
					'''
					+2{$CommonItemtooltip.ForItems.AccessorySlot}
					受到攻击时，释放反击能量束并暂时获得伤害提升
					{$CommonItemtooltip.ForItems.MoreTarget}
					'''
				Mechanical:
					'''
					+2{$CommonItemtooltip.ForItems.AccessorySlot}
					减少20%饰品技能冷却时间
					暴击会使敌人惊愕
					惊愕的敌人造成更低的接触伤害并受到更多的伤害
					'''
				Radiant:
					'''
					+1{$CommonItemtooltip.ForItems.AccessorySlot}
					召唤一个拥有近战,远程,魔法和召唤四种增幅模式的神秘水晶
					你和附近的其他玩家获得模式对应的伤害增幅
					拥有水晶的玩家(包括你)获得的增幅更大
					双击{0}切换增幅模式
					'''
				Tarnished:
					'''
					+1{$CommonItemtooltip.ForItems.AccessorySlot}
					饰品技能冷却时间不再增加
					如果你受到致命伤害，庇护之魂会复活你并回复100点生命
					复活效果触发后有5分钟的冷却时间
					'''
				Xeno:
					'''
					+2{$CommonItemtooltip.ForItems.AccessorySlot}
					你的盔甲会随时间充能一个吸收部分伤害的临时能量护盾
					'''
				Ornate:
					'''
					+1{$CommonItemtooltip.ForItems.AccessorySlot}
					饰品技能冷却时间不再增加
					+2防御
					'''
				Starplate:
					'''
					+1{$CommonItemtooltip.ForItems.AccessorySlot}
					饰品技能冷却时间不再增加
					根据昼夜获得不同效果的小幅提升：
					白天增加伤害和移动速度
					夜晚增加防御和生命再生
					'''
				Tech:
					'''
					+1{$CommonItemtooltip.ForItems.AccessorySlot}
					饰品技能冷却时间不再增加
					减少17%饰品技能冷却时间
					'''
			}

			PresentDeath: {
				Msg0: "{0}对幸运方块不擅长"
