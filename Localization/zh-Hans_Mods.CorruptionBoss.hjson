	}

	PunishmentCore: {
		DisplayName: 惩戒之核
		Tooltip: 命中时放出黑暗斩首刃
	}

	ShadeSplinter: {
		DisplayName: 影裂
		Tooltip:
			'''
			增加5%暴击率
			减少魔力再生延迟
			暴击有50%几率消耗魔力产生造成额外伤害的爆炸
			魔力使用量随魔力消耗降低效果和武器的攻击速度和暴击几率变化
			'''
	}

	Heartbreak: {
		DisplayName: 碎心
		Tooltip:
			'''
			免疫击退
			能将伤害反弹给攻击者
			受伤时抛出爆炸碎片
			受伤后增加移动速度
			'回味伤悲不如快意恩仇'
			'''
	}

	CrystallineUmbra: {
		DisplayName: 本影结晶
		Tooltip:
			'''
			增加10%暴击率
			减少魔力再生延迟
			敌人不太可能以你为目标
			暴击有50%几率消耗魔力产生造成额外伤害的爆炸
			魔力使用量随魔力消耗降低效果和武器的攻击速度和暴击几率变化
			'他们永远不会知道它的到来'
			'''
	}

	ShatteredShell: {
		DisplayName: 破碎外壳
		Tooltip:
			'''
			免疫击退
			能将伤害反弹给攻击者
			受伤时抛出爆炸碎片
			'它不会阻止敌人攻击你，但能让敌人后悔攻击你'
			'''
	}

	ShatterspikeBracer: {
		DisplayName: 碎钉护腕
		Tooltip:
			'''
			免疫击退
			能将伤害反弹给攻击者
			受伤时抛出爆炸碎片
			敌人更可能以你为目标
			'最好的防守，就是最好的进攻加上最好的防守'
			'''
	}

	SiphonStone: {
		DisplayName: 虹吸石
		Tooltip:
			'''
			增加5%魔法暴击率
			最大魔力增加40
			大幅减少魔力再生延迟
			暴击有50%几率消耗魔力产生造成额外伤害的爆炸
			魔力使用量随魔力消耗降低效果和武器的攻击速度和暴击几率变化
			'''
	}

	ShadowRing: {
		DisplayName: 暗影戒指
		Tooltip:
			'''
			召唤3个腐化卫核保护你并提高防御
			卫核能对接触的敌人造成伤害，并对敌人发出射弹
			卫核会受到敌人的伤害，伤害到达一定值后卫核会暂时破碎
			卫核受到的射弹伤害降低
			'尽管采用了极简主义的设计，但其优雅的外观仍具有强大的力量'
			'''
	}

	BloodyRing: {
		DisplayName: 血腥戒指
		Tooltip:
			'''
			召唤3个猩红卫核保护你并提高防御
			卫核能对接触的敌人造成伤害，并对敌人发出射弹
			卫核会受到敌人的伤害，伤害到达一定值后卫核会暂时破碎
			卫核受到的射弹伤害降低
			'这可不是时尚展示'
			'''
	}

	TaintedTrajectory: {
		DisplayName: 血污轨迹
		Tooltip:
			'''
			6% 召唤标记暴击率
			你的召唤物将集中攻击被打中的敌人
			击中敌人会在鞭子末端释放污秽的灵魂
			'''
	}

	OrbitalStaff: {
		DisplayName: 卫核法杖
		Tooltip:
			'''
			召唤微型腐化核心为你而战
			反复召唤给核心添加更多的卫核
			'该法杖由腐化团队赞助'
			'''
	}

	Bloodlust: {
		DisplayName: 嗜血
		Tooltip:
			'''
			释放带有吸取敌人生命光环的血珠
			光环根据伤害增加玩家的生命回复
			按住攻击键时血珠受到强化
			'你知道只有一件事是真的'
			'''
	}

	DefiledSpike: {
		DisplayName: 亵渎之刺
		Tooltip:
			'''
			释放绝命刺
			按住攻击键蓄能，释放更强大的绝命刺
			在攻击开始时造成额外伤害
			'''
	}

	SoulRing: {
		DisplayName: 灵魂戒指
		 Tooltip:
			'''
			召唤6个灵魂卫核保护你并提高防御
			卫核能对接触的敌人造成伤害，并对敌人发出射弹
			卫核会受到敌人的伤害，伤害到达一定值后卫核会暂时破碎
			卫核受到的射弹伤害降低
			'奇怪的是，尽管它由强大的灵魂能量组成，但它并不比类似的戒指更强。'
			''' 
	}

	CoreTrophyItemSoul: {
		DisplayName: 灵魂本影纪念章
		Tooltip: ""
	}

	CorePetItemSoul: {
		DisplayName: 本影核
		 Tooltip:
			'''
			召唤一个能照明的微型灵魂本影
			'尽管处于一种衰弱的状态，灵魂依然存在。'
			''' 
	}

	CoreMaskSoul: {
		DisplayName: 灵魂本影面具
		Tooltip: ""
	}

	CoreBossBagSoul: {
		DisplayName: 宝藏袋(皇冠之魂)
		Tooltip: ""
	}

	CrownOfFearSoul: {
		DisplayName: 灵魂皇冠
		 Tooltip:
			'''
			所有攻击造成暗影撕裂减益，快速损耗生命
			暗影撕裂会一直持续，直到造成了相当于攻击伤害20%的伤害
			连续攻击能延长暗影撕裂的持续时间
			免疫诅咒狱火和灵液
			可以作为头盔佩戴，增加大量防御
			'你现在是一位在战斗的熔炉中加冕的大师'
			''' 
	}

	CrownOfFearCrim: {
		DisplayName: 恐惧皇冠
		 Tooltip:
			'''
			所有攻击造成暗影撕裂减益，快速损耗生命
			暗影撕裂会一直持续，直到造成了相当于攻击伤害20%的伤害
			连续攻击能延长暗影撕裂的持续时间
			免疫诅咒狱火和灵液
			可以作为头盔佩戴，增加大量防御
			'恐惧的王冠现在获得了统治者'
			''' 
	}

	CrownOfFear: {
		DisplayName: 恐惧皇冠
		 Tooltip:
			'''
			所有攻击造成暗影撕裂减益，快速损耗生命
			暗影撕裂会一直持续，直到造成了相当于攻击伤害20%的伤害
			连续攻击能延长暗影撕裂的持续时间
			免疫诅咒狱火和灵液
			可以作为头盔佩戴，增加大量防御
			'暗影大师，恐惧之主'
			''' 
	}
}

Buffs: {
	CorePetBuff: {
		DisplayName: 腐化核心
		Description: 和仆从的差异只有外面的环
	}

	CorePetBuffCrim: {
		DisplayName: 猩红核心
		Description: 最强的猩红粉丝?
	}

	CorePetsBuff: {
		DisplayName: 邪恶核心
		Description: 两个比一个好!
	}

	TaintedTrajectoryTag: {
		DisplayName: 血污轨迹标记
		Description: 仆从可以对其造成暴击
	}

	CoreMinionBuff: {
		DisplayName: 核心仆从
		Description: 最弱的腐化享受者
	}

	BloodlustBuff: {
		DisplayName: 嗜血
		Description: 增加生命再生
	}

	ShadowTear: {
		DisplayName: 暗影撕裂
		Description: 快速失去生命
	}

	Dread: {
		DisplayName: 恐惧
		Description: 你见证了真正可怕的力量，无法逃脱。
	}

	UmbralOppresion: {
		DisplayName: 本影压迫
		Description: 核心纯粹的阴暗淹没了光，阻止生命再生和生命吸取
	}

	CorePetBuffSoul: {
		DisplayName: 本影慈爱
		Description: 核心纯粹而朦胧的力量...此版本中不存在
	}
}

Configs: {
	Config: {
		DisplayName: 配置

		Headers: {
			HeaderWeapons: 武器设定
			HeaderBoss: Boss设定
		}

		bossHealthMultiplier: {
			Label: 核心生命倍率
			Tooltip:
				'''
				BOSS血量的倍率
				也会影响卫核的血量，不影响影灵
				如果觉得核心战太难或太简单，可以调整该项.
				'''
		}

		wispHealthMultiplier: {
			Label: 影灵生命倍率
			Tooltip:
				'''
				核心召唤的影灵血量的倍率
				如果觉得核心战太难或太简单，可以调整该项.
				'''
		}

		bossDefenseMultiplier: {
			Label: 核心防御倍率
			Tooltip:
				'''
				BOSS防御的倍率
				也会影响卫核和影灵
				如果觉得核心战太难或太简单，可以调整该项.
				'''
		}

		bossDamageMultiplier: {
			Label: 核心伤害倍率
			Tooltip:
				'''
				BOSS伤害的倍率
				也会影响卫核和影灵,以及所有相关射弹
				如果觉得核心战太难或太简单，可以调整该项.
				'''
		}

		attackVelocityMultiplier: {
			Label: 核心弹速倍率
			Tooltip:
				'''
				BOSS发射的射弹速度的倍率
				也会影响卫核发射的射弹和影灵的移速
				还能改变影灵和怀旧模式的暗夜炸弹的转向速度
				如果觉得核心战太难或太简单，可以调整该项.
				'''
		}

		bossSpeedMultiplier: {
			Label: 核心速度倍率（怀旧模式）
			Tooltip:
				'''
				腐化核心与猩红核心速度的倍率
				同时调整核心的惯性，这决定了核心转弯的速度和幅度
				如果觉得核心战太难或太简单，可以调整该项.
				只对怀旧模式的BOSS有效，暗影核心不受影响
				'''
		}

		rangedWepDmgMultiplier: {
			Label: 远程武器伤害倍率
			Tooltip:
				'''
				诅咒卡宾枪和猩红铁炮伤害的倍率
				对其他武器无效
				猩红铁炮的生命吸取不与伤害成正比增加
				用于手动平衡武器的强度（可与BOSS倍率配合调整BOSS时期）
				'''
		}

		meleeWepDmgMultiplier: {
			Label: 近战武器伤害倍率
			Tooltip:
				'''
				惩戒之核与血腥偃月刀伤害的倍率
				对其他武器无效
				用于手动平衡武器的强度（可与BOSS倍率配合调整BOSS时期）
				'''
		}

		magicWepDmgMultiplier: {
			Label: 魔法武器伤害倍率
			Tooltip:
				'''
				亵渎之刺与嗜血伤害的倍率
				对其他武器无效
				嗜血的生命回复效果不会改变
				用于手动平衡武器的强度（可与BOSS倍率配合调整BOSS时期）
				'''
		}

		summonWepDmgMultiplier: {
			Label: 召唤武器伤害倍率
			Tooltip:
				'''
				卫核法杖与血污轨迹伤害的倍率
				对其他武器无效
				血污轨迹的标记暴击不受影响
				卫核法杖的仆从需要重新召唤更新其伤害
				用于手动平衡武器的强度（可与BOSS倍率配合调整BOSS时期）
				召唤武器往往随着伤害的增加而指数级增强，因此建议将倍率设置得低于其他武器
				'''
		}

		forcedAI: {
			Label: AI难度
			 Tooltip:
				'''
				允许你设置暗影核心的AI难度。选项如下;
				- 默认: AI由世界难度决定
				- 经典: 使用经典难度的AI
				- 专家: 使用专家难度的AI
				- EX: 攻击比专家难度的AI更强大，在正常情况下不会出现
				怀旧模式下无效!
				''' 
		}

		legacyMode: {
			Label: 怀旧模式
			 Tooltip:
				'''
				由之前版本的腐化核心替代暗影核心
				注意，可疑的球体被击碎时会直接生成腐化核心
				''' 
		}

		orbResistedProjs: {
			Label: 卫核射弹抗性
			 Tooltip:
				'''
				下列射弹对卫核的伤害减半,包括哨兵
				这是为了降低滞留型范围伤害对卫核的突出效果
				只影响暗影核心BOSS战，怀旧模式下无效!
				''' 
		}
	}
}

Emotes: {
	CoreEmote.Command: 腐核
	CoreEmoteCrim.Command: 血核
}
