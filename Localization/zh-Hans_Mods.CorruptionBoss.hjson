NPCs: {
	CoreBoss.DisplayName: 腐化核心
	CoreBossCrim.DisplayName: 猩红核心
	OrbitalI.DisplayName: 腐化卫核
	OrbitalICrim.DisplayName: 猩红卫核
	OrbitalII.DisplayName: 诅咒卫核
	OrbitalIICrim.DisplayName: 污染卫核
	ShadeWisp.DisplayName: 影灵
	SpawnerOrbCrim.DisplayName: 可疑的球体
	SpawnerOrb.DisplayName: 可疑的球体

	###
	# Core of Shadows update
	###
	SusOrbital: {
		DisplayName: 腐化卫核
		CrimsonName: 猩红卫核
	}

	SusOrb.DisplayName: 可疑的球体

	CoSBoss: {
		DisplayName: 暗影核心
		JokeName: 永恒本影
		SuperbossName: 灵魂本影
		 SuperbossBestiary:
			'''
			远古的光明与黑暗之魂无情的维持着平衡。
			然而，灵魂本就是由纯粹的光明和黑暗化成，本身就会破坏他们为之奋斗的平衡。
			或许他们互相毁灭或被外来者摧毁也是创始神设计好的一部分。
			...但化为概念的事物真的能被杀死吗?
			''' 
		 ChecklistTip:
			'''
			使用在腐化/猩红之地，或是夜晚使用[i:CorruptionBoss/ChargedOrbCoS]黄昏宝珠
			夜晚召唤会激怒BOSS，战斗更加困难
			''' 
	}

	ShadowOrbital: {
		DisplayName: 暗影卫核
		JokeName: 阴影护卫
		SuperbossName: 本影珠
		 SuperbossBestiary:
			'''
			击碎暗影珠会激起世界吞噬者的怒火，看样子它们对腐化之地有着神秘的重要性。
			或许它们是世界邪恶的源头、渠道或是聚合体。
			''' 
	}

	ChaosOrbital: {
		DisplayName: 混沌卫核
		JokeName: 幻影护卫
		SuperbossName: 灵魂珠
		 SuperbossBestiary:
			'''
			黑暗之魂用暗影珠释放出可怕的破坏力，在之后只留下一个破碎的外壳。
			那么，有多少能量来自黑暗之魂，有多少来自暗影珠呢?
			''' 
	}

	CoFBoss: {
		DisplayName: 恐惧皇冠
		JokeName: 总督皇冠
		SuperbossName: 皇冠之魂
		 Bestiary:
			'''
			失去统治者的恐怖皇冠。 
			这种燃烧的异常形态是对领袖和权威概念的邪恶讽刺。世界的邪恶是一种不可控制的力量，不会接受任何主人。
			''' 
		 SuperbossBestiary:
			'''
			在一个理想的世界里，一切都是公平公正的，没有一个生物会凌驾于另一个之上。 
			只有自由才能实行。
			灵魂将主宰自己。
			那是...安那其。
			''' 
	}

	CoSWisp.DisplayName: 影灵
}

CommonItemTooltip: {
	BestiaryEntryCorruptCore: 黑暗原能的恶意漩涡化身为了这个超载的暗影核心。当核心被卫核围绕时，它是无法被击中的。
	BestiaryEntryCorruptOrbitalI: 一个由古老黑暗灵魂支配的凶恶暗影珠。利用创造它的核心的力量，通过防御和进攻措施保护其主人。
	BestiaryEntryCorruptOrbitalII: 卫核的一种不稳定的变体。诅咒且不稳定的属性似乎是其支配者绝望的产物。讽刺的是，诅咒卫核比正常卫核更脆弱。
	BestiaryEntryCorruptSpawnerOrb: 这个暗影珠莫名其妙地偏离了腐化地表的裂隙，并散发出不祥的光芒。它引诱着泰拉人破坏自己，但谁知道后果有多可怕？
	BestiaryEntryCrimCore: 在猩红之地的浸染下，核心的力量和颜色发生了变化。尽管核心被污染了，但在其同样被污染的卫核围绕时，核心仍然不会受到攻击。
	BestiaryEntryCrimOrbitalI: 一个由黑暗灵能控制的的残暴猩红珠。操纵召唤它的核心的力量，通过防御和进攻措施保护其领袖。
	BestiaryEntryCrimOrbitalII: 猩红卫核的一种不稳定的变体。卫核的不稳定和腐蚀性是其创造者的鲁莽造成的。讽刺的是，这些变化使污染卫核更加弱小。
	BestiaryEntryCrimSpawnerOrb: 在克苏鲁的阴谋被摧毁后，一个不祥的球体神秘地出现在猩红深处。里面有什么邪恶的力量？
	SummonTipCorrupt: "'它对黑夜的黑暗和腐化的邪恶做出反应'"
	SummonTipCrim: "'它对黑夜的黑暗和猩红的邪恶做出反应'"
	AvailableHintCorrupt: 黑暗的气息渗透到了腐化的深处...
	AvailableHintCrim: 猩红的洞穴中弥漫着邪恶的气息...
	ChecklistDespawnCorrupt: 核心发泄愤怒后，莫名其妙地从视野中消失了
	ChecklistDespawnCrim: 在释放了怒火之后，核心不知怎么地消失得无影无踪
	ChecklistSpawnCorrupt: 在地下腐化找到并摧毁可疑的球体，或在晚上或腐化使用[i:CorruptionBoss/ChargedOrb]充能宝珠。只能存在于腐化世界
	ChecklistSpawnCrim: 在地下猩红找到并摧毁可疑的球体，或在晚上或猩红使用[i:CorruptionBoss/ChargedOrbCrim]充能宝珠。只能存在于猩红世界
	EquipPerksTipCorrupt:
		'''
		增益:
		免疫诅咒狱火
		提升少量防御
		'''
	EquipPerksTipCrim:
		'''
		增益:
		免疫灵液
		提升少量生命恢复
		'''
	EquipPerksTipMulti:
		'''
		增益:
		免疫诅咒狱火与灵液
		提升少量防御与生命恢复
		'''
}

